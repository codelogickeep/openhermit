{
  "name": "@codelogickeep/open-hermit",
  "version": "1.0.6",
  "description": "OpenHermit (开源寄居蟹) - A lightweight PTY bridge that connects Claude Code and local AI CLI agents to mobile messaging platforms (DingTalk). Enables remote access to your AI development environment from your phone.",
  "main": "src/index.js",
  "bin": {
    "openhermit": "./src/index.js"
  },
  "type": "module",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src/",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "npm rebuild node-pty --build-from-source",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "pty",
    "claude",
    "claude-code",
    "ai-agent",
    "cli-bridge",
    "dingtalk",
    "remote-terminal",
    "mobile-ide",
    "terminal",
    "ssh-alternative",
    "developer-tools",
    "remote-development",
    "openhermit"
  ],
  "author": "CodeLogicKeep",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codelogickeep/openhermit.git"
  },
  "homepage": "https://github.com/codelogickeep/openhermit#readme",
  "bugs": {
    "url": "https://github.com/codelogickeep/openhermit/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "dependencies": {
    "axios": "^1.6.0",
    "dingtalk-stream-sdk-nodejs": "^2.0.4",
    "dotenv": "^16.3.1",
    "lodash.debounce": "^4.0.8",
    "node-pty": "^1.1.0",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "strip-ansi": "^6.0.1"
  },
  "devDependencies": {
    "vitest": "^1.2.0"
  }
}
